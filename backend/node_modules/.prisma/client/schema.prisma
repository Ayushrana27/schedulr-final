generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EventType {
  id        Int      @id @default(autoincrement())
  title     String
  duration  Int
  slug      String   @unique
  createdAt DateTime @default(now())
}

model Availability {
  id        Int    @id @default(autoincrement())
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String
}

model Booking {
  id          Int    @id @default(autoincrement())
  name        String
  email       String
  date        String
  startTime   String
  endTime     String
  status      String @default("booked")
  eventTypeId Int
}
